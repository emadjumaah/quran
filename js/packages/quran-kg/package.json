{
  "name": "quran-kg",
  "version": "0.1.0",
  "description": "Typed API over the Quran Knowledge Graph — every word, segment, root, and lemma of the Quran with full morphology, in SQLite",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qataruts/quran-kg.git"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test \"test/*.test.mjs\""
  },
  "keywords": [
    "quran",
    "arabic",
    "morphology",
    "nlp",
    "knowledge-graph",
    "sqlite",
    "linguistics"
  ],
  "author": "Emad Jumaah <emadjumaah@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^22.10.0"
  }
}
